# Allow native build scripts
# See package.json pnpm.onlyBuiltDependencies

# pnpm 10 disables pre/post lifecycle scripts by default; re-enable so
# package `prepare`/`prepublishOnly`/`prepack` actually run during
# `pnpm publish`. Without this a manual publish skips `tsc` and ships an
# empty tarball — see @thebutler/pipeline 0.1.1.
enable-pre-post-scripts=true
