---
import FeatureRow from './FeatureRow.astro'
interface Props { reversed?: boolean; filled?: boolean }
const { reversed = false, filled = false } = Astro.props
---

<FeatureRow
  featureId="knows-guests"
  badge="Guest Intelligence"
  badgeColor="bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300"
  title="Knows Your Guests"
  description="Jack remembers every guest across visits — their preferences, past requests, and booking history. Returning guests feel recognised instantly."
  bullets={[
    'Guest profiles built automatically from conversations',
    'Syncs with your PMS for booking context',
    'All data stored on your server — never shared with third parties',
  ]}
  reversed={reversed}
  filled={filled}
>
  <div class="w-full max-w-sm">
    <div class="rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-xl overflow-hidden">
      <div class="bg-gradient-to-r from-purple-600 to-blue-600 p-6 text-white">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center text-2xl font-bold">S</div>
          <div>
            <p class="font-bold text-lg">Sarah M.</p>
            <p class="text-purple-200 text-sm">3rd visit · Room 204</p>
          </div>
          <div class="ml-auto">
            <div class="px-2.5 py-1 rounded-full bg-white/20 text-xs font-semibold flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block animate-pulse"></span>
              Checking in
            </div>
          </div>
        </div>
      </div>
      <div class="p-5">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wide mb-3">Preferences detected from past stays</p>
        <div id="guest-tags" class="flex flex-wrap gap-2 mb-4">
          <!-- JS-driven tag pop-in -->
        </div>
        <div id="guest-memory" class="flex items-center gap-3 p-3 rounded-xl bg-neutral-50 dark:bg-neutral-800 opacity-0 transition-opacity duration-500">
          <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="text-sm text-neutral-600 dark:text-neutral-400">Profile ready — Jack will greet her by name</p>
        </div>
      </div>
    </div>
  </div>
</FeatureRow>

<script>
  const guestTags = ['High floor', 'Extra pillows', 'Vegan breakfast', 'Late checkout', 'Quiet room', 'Twin beds']

  function animateGuestTags() {
    const container = document.getElementById('guest-tags')
    const memory = document.getElementById('guest-memory')
    if (!container) return
    if (memory) memory.style.opacity = '0'

    container.innerHTML = ''
    const spans: HTMLElement[] = guestTags.map((tag) => {
      const span = document.createElement('span')
      span.className = 'px-2.5 py-1 text-xs bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full border border-purple-200 dark:border-purple-800'
      span.style.opacity = '0'
      span.style.transform = 'scale(0.6)'
      span.style.transition = 'opacity 0.25s ease, transform 0.25s cubic-bezier(0.34,1.56,0.64,1)'
      span.textContent = tag
      container.appendChild(span)
      return span
    })

    spans.forEach((span, i) => {
      setTimeout(() => {
        span.style.opacity = '1'
        span.style.transform = 'scale(1)'

        if (i === spans.length - 1) {
          setTimeout(() => { if (memory) memory.style.opacity = '1' }, 400)
          setTimeout(animateGuestTags, 3500)
        }
      }, i * 300)
    })
  }

  const section = document.querySelector('[data-feature="knows-guests"]')
  const guestObserver = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      animateGuestTags()
      guestObserver.disconnect()
    }
  }, { threshold: 0.3 })
  if (section) guestObserver.observe(section)
</script>
